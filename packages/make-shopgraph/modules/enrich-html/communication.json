{
  "url": "{{base.baseUrl}}/api/enrich",
  "method": "POST",
  "headers": {
    "Content-Type": "application/json",
    "Authorization": "Bearer {{connection.apiKey}}"
  },
  "body": {
    "html": "{{parameters.html}}",
    "format": "{{parameters.format}}"
  },
  "response": {
    "output": {
      "product": "{{body.product}}",
      "cached": "{{body.cached}}",
      "credit_mode": "{{body.credit_mode}}"
    }
  }
}
